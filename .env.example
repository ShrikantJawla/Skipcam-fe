# Signaling server (Socket.io)
# Local: http://localhost:5000
# Production: https://skipcam-be.onrender.com
NEXT_PUBLIC_SIGNALING_URL=https://skipcam-be.onrender.com

# Optional TURN (needed when PC and phone are on different networks / cellular).
# Create free credentials at https://www.metered.ca/stun-turn then set:
# NEXT_PUBLIC_TURN_URLS=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:443
# NEXT_PUBLIC_TURN_USERNAME=your-username
# NEXT_PUBLIC_TURN_CREDENTIAL=your-password
